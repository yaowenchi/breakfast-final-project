PORT=3000
HOST=0.0.0.0
NODE_ENV=development
STORE_DRIVER=postgres

# Neon / PostgreSQL
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
DATABASE_URL_MIGRATION=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# Better Auth / Google OAuth
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=replace-with-a-long-random-secret
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:5173
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret

# Demo roles
BOSS_EMAIL=boss@example.com
BOSS_PASSWORD=replace-with-secure-password
BOSS_NAME=Boss

# Optional staff override. If omitted, demo@example.com / 1234 is staff.
STAFF_EMAIL=
STAFF_PASSWORD=
STAFF_NAME=
