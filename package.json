{
  "name": "00_demo01",
  "module": "backend.ts",
  "type": "module",
  "private": true,
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently \"cd frontend && bun run dev\" \"bun --watch backend.ts\"",
    "dev:backend": "bun --watch backend.ts",
    "dev:v8": "bun --watch backend.v8.ts",
    "dev:frontend": "cd frontend && bun run dev",
    "build:frontend": "cd frontend && bun run build",
    "build:backend": "bun build --target=bun ./backend.ts --outdir ./dist",
    "build": "bun run build:frontend && bun run build:backend",
    "start": "bun dist/backend.js",
    "start:render": "bun run db:migrate && bun run start",
    "preview:frontend": "cd frontend && bun run preview",
    "v8:db:setup": "bun scripts/setup-v8-legacy-db.ts",
    "db:check": "bun run ./scripts/db-check.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate-json": "bun run ./scripts/migrate-json.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^8.2.2",
    "drizzle-kit": "^0.30.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@elysiajs/openapi": "^1.4.14",
    "@elysiajs/static": "^1.4.7",
    "@neondatabase/serverless": "^1.0.2",
    "better-auth": "^1.6.7",
    "drizzle-orm": "^0.44.6",
    "elysia": "^1.4.28",
    "postgres": "^3.4.9",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^4.4.3"
  }
}
